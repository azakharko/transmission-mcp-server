{
  "name": "transmission-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Transmission BitTorrent client (JSON-RPC over HTTP only)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "transmission-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "keywords": [
    "mcp",
    "transmission",
    "torrent",
    "model-context-protocol"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
