{
  "name": "transmission-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Transmission BitTorrent client (JSON-RPC over HTTP only)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "transmission-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "Contributing.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm run test",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/azakharko/transmission-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/azakharko/transmission-mcp-server/issues"
  },
  "homepage": "https://github.com/azakharko/transmission-mcp-server#readme",
  "keywords": [
    "mcp",
    "transmission",
    "torrent",
    "model-context-protocol"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "fastmcp": "^4",
    "zod": "^4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.5"
  }
}
