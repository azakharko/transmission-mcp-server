# Copy to .env and fill in. Used by docker compose and local runs.
# Paths should match Transmission's view (absolute, normalized).

TRANSMISSION_RPC_USER=your-rpc-user
TRANSMISSION_RPC_PASSWORD=your-rpc-password
TRANSMISSION_ALLOWED_DOWNLOAD_DIRS=/var/lib/transmission-daemon/downloads

# Optional (defaults shown)
# TRANSMISSION_RPC_URL=http://127.0.0.1:9091/transmission/rpc
# TRANSMISSION_DEFAULT_DOWNLOAD_DIR=/var/lib/transmission-daemon/downloads
